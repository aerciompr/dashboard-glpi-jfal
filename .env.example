# URL base da API do GLPI (v1 recomendada para esta integração)
GLPI_API_BASE=https://seu-glpi/api.php/v1

# App-Token gerado no GLPI (Setup > General > API)
GLPI_APP_TOKEN=SEU_APP_TOKEN

# Autenticação: use OU token de usuário...
GLPI_USER_TOKEN=SEU_USER_TOKEN

# ...OU login/senha (se não usar GLPI_USER_TOKEN)
GLPI_LOGIN=
GLPI_PASSWORD=

# true: ignora certificado TLS inválido (somente rede interna)
# false: obrigatório para produção com certificado válido
GLPI_INSECURE_TLS=false

# Porta HTTP da aplicação (frontend build + API proxy)
API_PORT=8787

# Normalmente vazio quando o frontend é servido pelo mesmo backend
VITE_BACKEND_URL=

# URL para abrir o chamado no GLPI ao clicar em "Visualizar"
VITE_GLPI_TICKET_URL=https://glpi.jfal.jus.br/front/ticket.form.php?id=
